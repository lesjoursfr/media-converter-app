{
	"name": "media-converter-app",
	"version": "1.0.0",
	"private": true,
	"description": "Electron application to convert audio & video files with ffmpeg",
	"keywords": [
		"electron",
		"ffmpeg",
		"converter"
	],
	"author": "",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lesjoursfr/media-converter-app.git"
	},
	"homepage": "https://github.com/lesjoursfr/media-converter-app#readme",
	"bugs": {
		"url": "https://github.com/lesjoursfr/media-converter-app/issues"
	},
	"engines": {
		"node": "24.x || 26.x"
	},
	"scripts": {
		"freshlock": "rm -rf node_modules/ && rm .yarn/install-state.gz && rm yarn.lock && yarn",
		"check-lint": "eslint",
		"check-format": "prettier --check .",
		"check-tsc": "tsc --noEmit",
		"lint": "eslint --fix",
		"format": "prettier --write .",
		"build": "tsc -p tsconfig.json && node copy-assets.mjs",
		"start": "npm run build && electron .",
		"test": "npm run build && node --test test/**/*.test.mjs"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@tsconfig/node24": "24.0.4",
		"@types/fluent-ffmpeg": "2.1.28",
		"@types/node": "24.13.2",
		"@types/progress": "2.0.7",
		"@types/yargs": "17.0.35",
		"electron": "42.4.1",
		"eslint": "10.5.0",
		"eslint-config-prettier": "10.1.8",
		"globals": "17.7.0",
		"prettier": "3.8.4",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.0"
	},
	"packageManager": "yarn@4.17.0"
}
