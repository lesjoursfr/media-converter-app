{
	"extends": "./node_modules/@tsconfig/node24/tsconfig.json",
	"compilerOptions": {
		/* Visit https://aka.ms/tsconfig.json to read more about this file */
		"lib": [
			"es2024",
			"ESNext.Array",
			"ESNext.Collection",
			"ESNext.Error",
			"ESNext.Iterator",
			"ESNext.Promise",
			"DOM",
			"DOM.Iterable"
		],
		"outDir": "dist",
		"rootDir": ".",
		"types": ["node"]
	},
	"include": ["src/**/*", "forge.config.ts"],
	"exclude": ["node_modules", "**/*.spec.ts"]
}
